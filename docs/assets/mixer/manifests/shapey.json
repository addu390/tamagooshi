      ] },
    { "id": "brows", "name": "Brows", "at": [66, 63], "mirror": 80, "optional": true, "default": "none",
      "parts": [
        { "id": "flat", "src": "brow/a.png" },
        { "id": "slant", "src": "brow/b.png" },
        { "id": "short", "src": "brow/c.png" },
        { "id": "thick", "src": "brow/d.png" }
      ] },
    { "id": "mouth", "name": "Mouth", "at": [80, 97],
      "parts": [
        { "id": "moody", "src": {
            "open": "mouth/happy.png", "blink": "mouth/happy.png",
            "happy": "mouth/happy.png", "sleepy": "mouth/smirk.png",
            "worried": "mouth/sad.png", "alert": "mouth/sad.png" } }
      ] }
  ]
